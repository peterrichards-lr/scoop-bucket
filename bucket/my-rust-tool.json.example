{
    "version": "0.1.0",
    "description": "Template for a Rust tool built from source",
    "homepage": "https://github.com/<user>/<repo>",
    "license": "MIT",
    "url": "https://github.com/<user>/<repo>/archive/refs/tags/v0.1.0.tar.gz",
    "hash": "<sha256-hash>",
    "extract_dir": "<repo>-0.1.0",
    "depends": "rustup",
    "installer": {
        "script": "cargo install --path . --root \"$dir\""
    },
    "bin": "bin/<tool-binary-name>.exe",
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/<user>/<repo>/archive/refs/tags/v$version.tar.gz",
        "extract_dir": "<repo>-$version",
        "hash": {
            "url": "$url",
            "mode": "download"
        }
    }
}
