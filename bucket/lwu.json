{
    "version": "1.0.0",
    "description": "A CLI tool to automatically update the Liferay Workspace Gradle plugin to its latest version",
    "homepage": "https://github.com/peterrichards-lr/lwu",
    "license": "MIT",
    "url": "https://github.com/peterrichards-lr/lwu/archive/refs/tags/v1.0.0.tar.gz",
    "hash": "8d309f7196dda3763101e6a65681e312aa1169a4a736cee10c2d5dda654eb7c6",
    "extract_dir": "lwu-1.0.0",
    "depends": "rustup",
    "installer": {
        "script": [
            "Set-Location "$dir"",
            "cargo install --path . --root "$dir""
        ]
    },
    "bin": "bin/lwu.exe",
    "checkver": "github",
    "autoupdate": {
        "url": "https://github.com/peterrichards-lr/lwu/archive/refs/tags/v$version.tar.gz",
        "extract_dir": "lwu-$version",
        "hash": {
            "url": "$url",
            "mode": "download"
        }
    }
}
